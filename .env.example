# Frontend (Vite) — safe to expose in browser
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Import script only — NEVER put in frontend .env
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Brevo — scripts + API route (never expose in VITE_* vars)
BREVO_API_KEY=your-brevo-api-key
BREVO_SENDER_EMAIL=231001053@rajalakshmi.edu.in
BREVO_SENDER_NAME=Project Allotment Portal - REC

# Optional: deploy Edge Function via CLI
# SUPABASE_ACCESS_TOKEN=your-personal-access-token

# Optional: for npm run apply-rls-fix (Database → Connection string URI)
# DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
